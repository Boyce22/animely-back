# ── Ambiente ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
RATE_LIMIT=100
LOG_DIR=./logs

# ── Database ───────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=animely
DB_SCHEMA=c0

# ── JWT ────────────────────────────────────────────────
JWT_SECRET=change-me-minimum-32-characters-long!!
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-32-characters-min!!
JWT_REFRESH_EXPIRES_IN=30d

# ── Storage (escolha um provedor) ──────────────────────
STORAGE_PROVIDER=cloudinary

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3 (descomente se STORAGE_PROVIDER=s3)
# AWS_REGION=
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Backblaze B2 (descomente se STORAGE_PROVIDER=backblaze)
# BACKBLAZE_KEY_ID=
# BACKBLAZE_APP_KEY=
# BACKBLAZE_BUCKET_ID=
# BACKBLAZE_BUCKET_NAME=
# BACKBLAZE_DOWNLOAD_URL=
