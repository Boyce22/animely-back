                  "raw": "{\n  \"version\": 2,\n  \"grid\": { \"cols\": 12, \"rowHeight\": 40, \"gap\": 8 },\n  \"theme\": {\n    \"background\": { \"type\": \"solid\", \"color\": \"#0f0f0f\" },\n    \"textColor\": \"#ffffff\",\n    \"accentColor\": \"#7c3aed\",\n    \"cardStyle\": \"glass\",\n    \"overlay\": { \"type\": \"hearts\", \"color\": \"#ff69b4\", \"opacity\": 0.3, \"density\": 20, \"speed\": 1 }\n  },\n  \"widgets\": [\n    {\n      \"id\": \"avatar-1\",\n      \"type\": \"AVATAR_CARD\",\n      \"visible\": true,\n      \"position\": { \"x\": 0, \"y\": 0, \"w\": 3, \"h\": 6 },\n      \"style\": { \"borderRadius\": \"12px\", \"boxShadow\": \"0 4px 24px rgba(0,0,0,0.5)\" },\n      \"config\": {}\n    },\n    {\n      \"id\": \"bio-1\",\n      \"type\": \"BIO\",\n      \"visible\": true,\n      \"position\": { \"x\": 3, \"y\": 0, \"w\": 9, \"h\": 3 },\n      \"style\": { \"background\": \"rgba(255,255,255,0.05)\", \"backdropFilter\": \"blur(8px)\", \"borderRadius\": \"12px\" },\n      \"config\": {}\n    },\n    {\n      \"id\": \"fav-anime-1\",\n      \"type\": \"FAVORITE_ANIME\",\n      \"title\": \"Favorite Anime\",\n      \"visible\": true,\n      \"position\": { \"x\": 0, \"y\": 6, \"w\": 6, \"h\": 6 },\n      \"style\": { \"borderRadius\": \"8px\" },\n      \"config\": { \"maxItems\": 6 }\n    },\n    {\n      \"id\": \"fav-manga-1\",\n      \"type\": \"FAVORITE_MANGA\",\n      \"title\": \"Favorite Manga\",\n      \"visible\": true,\n      \"position\": { \"x\": 6, \"y\": 6, \"w\": 6, \"h\": 6 },\n      \"style\": { \"borderRadius\": \"8px\" },\n      \"config\": { \"maxItems\": 6 }\n    }\n  ]\n}"
                },
